{
  "name": "payment-plugin-salesforce",
  "version": "1.4.0",
  "main": "index.js",
  "license": "MIT",
  "paths": {
    "base": "../storefront-reference-architecture/cartridges/app_storefront_base/"
  },
  "scripts": {
    "build": "gulp && npm run build --prefix packages/bm-web",
    "build-compile": "npm run build && sgmf-scripts --compile js && npm run fetch-bm-web",
    "fetch-bm-web": "cp packages/bm-web/dist/index.js cartridges/bm_airwallex/cartridge/static/default/",
    "compile:js": "sgmf-scripts --compile js",
    "test": "jest --runInBand --no-cache",
    "test:changed": "jest -o --runInBand --no-cache",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "uploadCartridge:bm": "sgmf-scripts --uploadCartridge bm_airwallex",
    "uploadCartridge:bm:env": "source .env && sgmf-scripts --uploadCartridge $BM_AIRWALLEX_CARTRIDGE_NAME",
    "uploadCartridge:int": "sgmf-scripts --uploadCartridge int_airwallex",
    "uploadCartridge:int:env": "source .env && sgmf-scripts --uploadCartridge $INT_AIRWALLEX_CARTRIDGE_NAME",
    "uploadCartridge:app": "sgmf-scripts --uploadCartridge app_airwallex",
    "uploadCartridge:app:env": "source .env && sgmf-scripts --uploadCartridge $APP_AIRWALLEX_CARTRIDGE_NAME",
    "uploadCartridge": "sgmf-scripts --uploadCartridge bm_airwallex && sgmf-scripts --uploadCartridge int_airwallex && sgmf-scripts --uploadCartridge app_airwallex",
    "uploadCartridge:env": "source .env && sgmf-scripts --uploadCartridge $BM_AIRWALLEX_CARTRIDGE_NAME && sgmf-scripts --uploadCartridge $INT_AIRWALLEX_CARTRIDGE_NAME && sgmf-scripts --uploadCartridge $APP_AIRWALLEX_CARTRIDGE_NAME",
    "postinstall": "npm install --prefix packages/bm-web"
  },
  "devDependencies": {
    "@airwallex/components-sdk": "^1.27.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jquery": "^3.5.33",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "axios": "^1.13.6",
    "del": "6.1.1",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.2",
    "gulp": "^5.0.1",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-typescript": "^6.0.0-alpha.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.7.4",
    "sgmf-scripts": "^4.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "arrowParens": "always",
    "trailingComma": "all"
  }
}
